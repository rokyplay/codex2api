  "prompt_cache": {
    "enabled": true,
    "session_id_strategy": "client_or_derived",
    "default_retention": null,
    "allow_client_override": true
  },
  "fake_non_stream": true,
  "stats": {
    "enabled": true,
    "retention_days": 30,
    "recent_buffer_size": 200
  },
  "abuse_detection": {
    "enabled": true,
    "retention_days": 90,
    "cleanup_interval_hours": 6,
    "actions": {
      "throttle_min_interval_ms": 3000
    },
    "thresholds": {
      "observe_max": 49,
      "throttle_min": 50,
      "challenge_min": 60,
      "suspend_min": 80
    },
    "auto_decay": {
      "enabled": true,
      "interval_ms": 600000,
      "description": "10分钟无新违规自动恢复到observe"
    },
    "rules": {
      "high_frequency": {
        "enabled": true,
        "threshold": 120,
        "score": 20
      },
      "high_concurrency": {
        "enabled": true,
        "threshold": 20,
        "score": 15
      },
      "multi_account_ip": {
        "enabled": true,
        "threshold": 5,
        "score": 20
      },
      "no_sleep_window": {
        "enabled": true,
        "threshold": 90,
        "score": 10
      },
      "periodic_pattern": {
        "enabled": true,
        "max_cv": 0.35,
        "min_samples": 12,
        "score": 15
      },
      "high_error_rate": {
        "enabled": true,
        "threshold": 0.5,
        "min_requests": 20,
        "score": 15
      },
      "token_abuse": {
        "enabled": true,
        "threshold": 50000000,
        "score": 20
      }
    }
  },
  "register": {
    "enabled": true,
    "api_url": "http://YOUR_REGISTER_HOST:YOUR_REGISTER_PORT",
